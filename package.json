  "scripts": {
    "android": "one run:android",
    "build": "one build",
    "check": "tko check",
    "check:all": "tko check --all",
    "postinstall": "bun run ./scripts/postinstall.ts",
    "ci": "NODE_ENV=production dotenvx run -f .env .env.production -- bun scripts/ci/release.ts",
    "clean": "rm -rf dist .expo",
    "dev": "one dev",
    "dev:dkg": "bash scripts/dev-dkg-service.sh",
    "env:dev": "NODE_ENV=development dotenvx run -f .env .env.development --",
