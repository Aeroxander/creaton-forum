    "format:check": "oxfmt --check",
    "format": "oxfmt",
    "lint:fix": "oxfmt && oxlint --import-plugin --type-aware --fix --fix-suggestions",
    "lint": "oxlint --import-plugin --type-aware",
    "prebuild:native": "one prebuild",
    "run:dev": "bun env:dev bun",
    "run:prod": "NODE_ENV=production dotenvx run -f .env .env.production -- bun",
    "run:test": "bun env:test bun",
    "test:integration": "bun run env:dev bun --cwd=./src/test playwright test",
    "test:unit": "bun run:dev vitest run -c ./src/test/vitest.config.ts",
    "test": "bun run test:unit",
    "up": "tko up",
    "validate:lexicons": "bash scripts/validate-lexicons.sh",
    "dev:encrypted-forum": "bash scripts/start-encrypted-forum-dev.sh"
