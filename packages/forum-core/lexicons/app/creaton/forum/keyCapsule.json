{
  "lexicon": 1,
  "id": "app.creaton.forum.keyCapsule",
  "defs": {
    "main": {
      "type": "record",
      "description": "A per-record content key wrapped to the active CREATE threshold committee.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["board", "recordUri", "committeeEpoch", "policyHash", "version", "suite", "encapsulation", "nonce", "ciphertext", "keyCommitment", "createdAt"],
        "properties": {
          "board": { "type": "ref", "ref": "com.atproto.repo.strongRef" },
          "recordUri": { "type": "string", "format": "at-uri" },
          "committeeEpoch": { "type": "integer", "minimum": 1 },
          "policyHash": { "type": "bytes" },
          "version": { "type": "integer", "minimum": 1, "maximum": 1 },
          "suite": { "type": "string", "knownValues": ["BLS12-381-THRESHOLD-DH/HKDF-SHA256/AES-256-GCM"] },
          "encapsulation": { "type": "bytes" },
          "nonce": { "type": "bytes" },
          "ciphertext": { "type": "bytes" },
          "keyCommitment": { "type": "bytes" },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
